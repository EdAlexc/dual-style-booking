# Copy to .env (or .env.local) and fill in your values.

# From the Neon console (or `neon data-api` CLI): the branch's Neon Auth URL
# and Data API URL.
NEXT_PUBLIC_NEON_AUTH_URL=
NEXT_PUBLIC_NEON_DATA_API_URL=

# Mux playback IDs for the landing-page hero videos (assets need MP4 support
# enabled). Optional — leave empty to fall back to /public/videos/*.mp4.
NEXT_PUBLIC_MUX_PLAYBACK_ID_GLAM=
NEXT_PUBLIC_MUX_PLAYBACK_ID_BOLD=
