# Public client configuration (no secrets — these values ship in the browser
# bundle). Next.js loads this file automatically for dev and CI builds.

# Neon Data API (PostgREST-style) + Neon Auth (issues the anonymous JWTs used
# by the booking form). Access is enforced by Postgres grants + RLS.
NEXT_PUBLIC_NEON_AUTH_URL=https://ep-spring-shape-ajchdw37.neonauth.c-3.us-east-2.aws.neon.tech/neondb/auth
NEXT_PUBLIC_NEON_DATA_API_URL=https://ep-spring-shape-ajchdw37.apirest.c-3.us-east-2.aws.neon.tech/neondb/rest/v1

# Mux playback IDs for the landing-page hero videos (public IDs, not secrets).
# Leave empty to fall back to /public/videos/{glam,bold}.mp4 / poster images.
NEXT_PUBLIC_MUX_PLAYBACK_ID_GLAM=
NEXT_PUBLIC_MUX_PLAYBACK_ID_BOLD=
